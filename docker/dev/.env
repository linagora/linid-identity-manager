################################################################################
#                             LINID-IM-API CONFIGURATION                       #
################################################################################

# PostgreSQL database host
DATABASE_HOST=localhost

# PostgreSQL database port
DATABASE_PORT=5432

# Name of the database
DATABASE_NAME=linid-db

# Database admin username
DATABASE_ADMIN_USER=admin

# Database admin password
DATABASE_ADMIN_PASSWORD=password

# Database username
DATABASE_USER=linid_user

# Database password
DATABASE_PASSWORD=password

# Enable or disable Swagger UI
SWAGGER_ENABLED=true

# Logging level (DEBUG, INFO, WARN, ERROR)
LOGGING_LEVEL=INFO

# OIDC issuer URI; must match the "iss" claim in JWTs (the portal URL as seen by the browser)
AUTH_ISSUER_URI=https://localhost:8080

# JWK Set URI; direct HTTP access to LemonLDAP for fetching public keys
AUTH_JWK_SET_URI=http://localhost:8080/oauth2/jwks

# Path to SSL/TLS key store
SSL_KEY_STORE=classpath:keystore.jks

# Password for accessing the SSL key store
SSL_KEY_STORE_PASSWORD=password

# Password for the individual SSL key within the key store
SSL_KEY_PASSWORD=password

# Path to SSL/TLS trust store
SSL_TRUSTSTORE_PATH=classpath:truststore.jks

# Password for accessing the SSL/TLS trust store
SSL_TRUSTSTORE_PASSWORD=changeit

# Path to client-specific Flyway migrations. Can be a filesystem path or classpath.
CLIENT_DATABASE_MIGRATION_PATH=filesystem:docker/dev/resources/db-client

# Schema name for client-specific Flyway migrations. Defaults to "public" if not set.
# CLIENT_DATABASE_SCHEMA=public

# Path to an external configuration file. This allows overriding or extending default application properties without modifying the main configuration.
EXTERNAL_CONFIGURATION=/app/extra-configuration.yaml

# Directory where plugin JARs are located. The service will scan this folder at startup (and possibly at runtime)
plugin.loader.path=docker/plugins

# Directory containing external i18n JSON files (e.g., en.json, fr.json). These translations are merged according to the merge order
i18n.external.path=docker/dev/resources/i18n

# Comma-separated list defining merge precedence for translations. Default: plugin,external,internal.
i18n.merge.order=plugin,external,internal

# Defines the copyright mode. Possible values:
# - default: applies default copyright enforcement.
# - custom: applies a custom copyright message.
# - none: disables copyright enforcement.
copyright.mode=custom

# Custom copyright message to apply when copyright.mode=custom.
copyright.custom=Your copyright here

################################################################################
#                             LEMONLDAP CONFIGURATION                          #
################################################################################

# Hostname for the LemonLDAP::NG portal, used in OIDC configuration
LEMONLDAP_PORTAL_HOSTNAME=localhost

# Port for the LemonLDAP::NG portal
LEMONLDAP_PORTAL_PORT=8080

# Database configuration for LemonLDAP::NG
LEMONLDAP_DATABASE_ADMIN_USER=admin

# Database admin password for LemonLDAP::NG
LEMONLDAP_DATABASE_ADMIN_PASSWORD=password

# Database username for LemonLDAP::NG
LEMONLDAP_DATABASE_USER=linid_user

# Database password for LemonLDAP::NG
LEMONLDAP_DATABASE_PASSWORD=password

# Database name for LemonLDAP::NG
LEMONLDAP_DATABASE_NAME=linid-db

# Domain of the LemonLDAP portal
LEMONLDAP_SSO_DOMAIN=localhost

# Redirect URL after LemonLDAP authentication
LEMONLDAP_REDIRECT_URL=https://localhost:9000/callback

# Full URL of the LemonLDAP portal
LEMONLDAP_PORTAL_URL=https://localhost:8080
