{
  "default": {
    "q-btn": {
      "dense": false,
      "outline": true,
      "color": "primary",
      "noCaps": true,
      "unelevated": true
    },
    "q-splitter": {
      "modelValue": 25
    },
    "q-tabs": {
      "dense": false,
      "align": "left",
      "noCaps": true,
      "inlineLabel": true,
      "activeBgColor": "primary"
    },
    "q-route-tab": {
      "noCaps": true
    },
    "q-table": {
      "dense": true
    },
    "q-header": {
      "elevated": true
    },
    "q-toolbar": {
      "inset": false
    },
    "q-toolbar-title": {
      "shrink": false
    },
    "q-badge": {
      "color": "primary",
      "align": "middle",
      "floating": false
    },
    "q-input": {
      "dense": true,
      "outlined": true
    },
    "q-card-actions": {
      "align": "right"
    },
    "q-avatar": {
      "size": "md",
      "color": "primary"
    },
    "q-icon": {
      "size": "sm"
    },
    "q-toggle": {
      "dense": true,
      "color": "primary"
    },
    "q-card": {
      "flat": true,
      "bordered": false
    },
    "q-date": {},
    "q-img": {},
    "q-file": {
      "dense": true,
      "outline": true,
      "color": "primary"
    },
    "q-select": {
      "outlined": true,
      "dense": true
    },
    "q-spinner": {},
    "q-btn-dropdown": {},
    "q-list": {},
    "q-item": {},
    "q-item-section": {},
    "q-item-label": {}
  },
  "base-layout": {
    "header": {
      "q-img": {
        "src": "/toolbarApplicationLogo.svg"
      },
      "header-profile": {
        "q-btn": {
          "flat": true,
          "textColor": "white"
        },
        "q-item-section": {
          "avatar": true
        },
        "q-item-label": {
          "caption": true
        }
      }
    }
  },
  "accounts": {
    "homepage": {
      "create-button": {
        "q-btn": {
          "outline": false
        }
      },
      "buttons-card": {
        "see-button": {
          "q-btn": {
            "flat": true
          }
        }
      }
    },
    "creation-page": {
      "buttons-card": {
        "confirm-button": {
          "q-btn": {
            "outline": false
          }
        }
      }
    },
    "details-page": {
      "entity-details-card": {
        "firstname": {
          "information-card": {
            "q-icon": { "color": "primary", "name": "account_circle" }
          }
        },
        "lastname": {
          "information-card": {
            "q-icon": { "color": "primary", "name": "account_circle" }
          }
        },
        "email": {
          "information-card": {
            "q-icon": { "color": "primary", "name": "mail" }
          }
        },
        "createdBy": {
          "information-card": {
            "q-icon": { "color": "primary", "name": "person_add" }
          }
        },
        "updatedBy": {
          "information-card": {
            "q-icon": { "color": "primary", "name": "manage_accounts" }
          }
        },
        "insertDate": {
          "information-card": {
            "q-icon": { "color": "primary", "name": "event_available" }
          }
        },
        "updateDate": {
          "information-card": {
            "q-icon": { "color": "primary", "name": "update" }
          }
        }
      },
      "activation-actions": {
        "dropdown-button": {
          "q-btn-dropdown": { "color": "positive", "outline": false }
        }
      },
      "suspension-actions": {
        "dropdown-button": {
          "q-btn-dropdown": { "color": "warning", "outline": false }
        }
      },
      "deactivation-actions": {
        "dropdown-button": {
          "q-btn-dropdown": { "color": "negative", "outline": false }
        }
      }
    }
  },
  "organizational-units": {
    "creation-page": {
      "buttons-card": {
        "confirm-button": {
          "q-btn": {
            "outline": false
          }
        }
      }
    }
  },
  "account-status-badge": {
    "active": {
      "q-badge": {
        "color": "positive",
        "align": "middle"
      }
    },
    "inactive": {
      "q-badge": {
        "color": "negative",
        "align": "middle"
      }
    },
    "suspended": {
      "q-badge": {
        "color": "warning",
        "align": "middle"
      }
    }
  },
  "account-deactivated-info-text": {
    "q-icon": {
      "name": "warning",
      "size": "xs"
    }
  },
  "account-suspended-info-text": {
    "q-icon": {
      "name": "warning",
      "size": "xs"
    }
  },
  "account-deactivated-banner": {
    "q-icon": {
      "color": "white",
      "name": "warning"
    },
    "reactivate-immediate-button": {
      "q-btn": {
        "color": "white",
        "textColor": "negative",
        "outline": false,
        "icon": "error"
      }
    },
    "reactivate-scheduled-button": {
      "q-btn": {
        "color": "white"
      }
    }
  },
  "account-deactivated-warning-banner": {
    "q-banner": {
      "color": "negative"
    },
    "q-icon": {
      "color": "negative",
      "name": "warning"
    },
    "deactivate-immediate-button": {
      "q-btn": {
        "color": "negative",
        "outline": false,
        "icon": "error"
      }
    },
    "modify-deactivation-button": {
      "q-btn": {
        "color": "negative"
      }
    }
  },
  "account-suspended-banner": {
    "q-icon": {
      "color": "white",
      "name": "warning"
    },
    "clear-suspension-button": {
      "q-btn": {
        "color": "white",
        "textColor": "warning",
        "outline": false,
        "icon": "error"
      }
    },
    "modify-suspension-button": {
      "q-btn": {
        "color": "white"
      }
    }
  },
  "tree": {
    "GenericTree": {
      "q-tree": {
        "selectedColor": "primary",
        "defaultExpandAll": true
      }
    }
  }
}
