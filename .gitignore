ui/node_modules/
ui/dist/
ui/.quasar/
ui/coverage/

# Generated files
docker/**/*.crt
docker/**/*.key
docker/**/*.pub
docker/**/*.jks
docker/dev/resources/llng
docker/e2e/resources/local
docker/e2e/resources/ci
api/**/*.jks
