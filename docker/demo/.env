################################################################################
#                             LINID-IM-API CONFIGURATION                       #
################################################################################
# Configuration file
CONFIGURATION_PATH=/config/config.yaml

# Plugin loader path
PLUGIN_LOADER_PATH=/plugins

# I18N external path
I18N_EXTERNAL_PATH=/i18n

# Allow all authorization for tests
AUTHORIZATION_ACCEPT_ALLOW_ALL=true

################################################################################
#                             LINID-IM-DATABASE CONFIGURATION                  #
################################################################################

# Name of the PostgreSQL database to connect to
DATABASE_NAME=linid

# Username to authenticate with PostgreSQL
DATABASE_USER=linid_admin

# Password for the PostgreSQL user
DATABASE_PASSWORD=password

# Port on the host machine to map to PostgreSQL
DATABASE_PORT=5432

################################################################################
#                             E2E TESTS CONFIGURATION                          #
################################################################################
# Path to Cucumber feature files used for E2E tests
CYPRESS_FEATURES_PATH=../features

# Base URL of the Frontend to be tested in E2E scenarios
E2E_FRONT_URL=http://localhost:9000

# Base URL of the API to be tested in E2E scenarios
E2E_API_URL=http://localhost:8080
