{
  "name": "@linagora/linid-identity-manager-ui",
  "version": "0.7.0",
  "description": "The host app of LinID Identity Manager",
  "productName": "LinID Identity Manager",
  "contributors": [
    {
      "name": "Vincent Moittie",
      "email": "moittie.vincent@gmail.com",
      "url": "https://github.com/Zorin95670"
    },
    {
      "name": "Jordy Cabannes",
      "email": "jcabannes@linagora.com",
      "url": "https://github.com/jcabannes"
    },
    {
      "name": "Christophe Chevalier",
      "email": "cchevalier@linagora.com",
      "url": "https://github.com/christophechevalier"
    }
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "type-check": "vue-tsc --noEmit",
    "validate": "pnpm type-check && pnpm lint && pnpm format:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=dot",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@linagora/linid-im-front-corelib": "0.0.83",
    "@module-federation/enhanced": "2.7.0",
    "@quasar/extras": "2.0.2",
    "axios": "1.18.1",
    "dayjs": "1.11.21",
    "nunjucks": "3.2.4",
    "oidc-client-ts": "3.5.0",
    "pinia": "3.0.4",
    "quasar": "2.21.1",
    "rxjs": "7.8.2",
    "vue": "3.5.39",
    "vue-i18n": "11.4.6",
    "vue-router": "5.1.0",
    "interactjs": "1.10.27"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@intlify/unplugin-vue-i18n": "11.2.4",
    "@module-federation/vite": "1.16.13",
    "@quasar/app-vite": "2.6.2",
    "@quasar/quasar-app-extension-testing-unit-vitest": "1.2.4",
    "@quasar/vite-plugin": "1.12.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/vue": "8.1.0",
    "@types/node": "26.1.1",
    "@types/nunjucks": "3.2.6",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.9.0",
    "@vue/test-utils": "2.4.11",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.4",
    "eslint-plugin-headers": "1.3.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "63.0.12",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "happy-dom": "20.10.6",
    "prettier": "3.9.4",
    "prettier-plugin-jsdoc": "1.8.1",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vite-plugin-checker": "0.14.4",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "pnpm": ">=10.32.1"
  },
  "packageManager": "pnpm@11.10.0"
}
