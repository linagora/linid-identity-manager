# Logs
*.log

# Local overrides
docker-compose.override.yml

# Plugin JARs (downloaded at runtime)
docker/plugins/

# Intellij
.idea

# UI build artifacts (handled by ui/.gitignore but also ignored at root)
ui/node_modules/
ui/dist/
ui/.quasar/
ui/coverage/

# Generated files
docker/**/*.crt
docker/**/*.key
api/**/*.jks
