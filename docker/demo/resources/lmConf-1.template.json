{
  "authentication": "DBI",
  "cfgDate": 1711324800,
  "cfgNum": 1,
  "dbiAuthChain": "dbi:Pg:dbname=${LEMONLDAP_DATABASE_NAME};host=db",
  "dbiAuthUser": "${LEMONLDAP_DATABASE_ADMIN_USER}",
  "dbiAuthPassword": "${LEMONLDAP_DATABASE_ADMIN_PASSWORD}",
  "dbiAuthTable": "lemonldap_accounts",
  "dbiAuthLoginCol": "username",
  "dbiAuthPasswordCol": "password",
  "dbiAuthPasswordHash": "",
  "dbiUserChain": "dbi:Pg:dbname=${LEMONLDAP_DATABASE_NAME};host=db",
  "dbiUserUser": "${LEMONLDAP_DATABASE_USER}",
  "dbiUserPassword": "${LEMONLDAP_DATABASE_PASSWORD}",
  "dbiUserTable": "lemonldap_accounts",
  "dbiPasswordMailCol": "mail",
  "userPivot": "username",
  "dbiExportedVars": {
    "cn": "cn",
    "mail": "mail",
    "uid": "username",
    "roles": "roles"
  },
  "domain": "${LEMONLDAP_SSO_DOMAIN}",
  "issuerDBOpenIDConnectActivation": 1,
  "key": "t3st-s3cr3t-k3y!",
  "locationRules": {
    "${LEMONLDAP_SSO_DOMAIN}": {
      "(?#errors)^/lmerror/": "accept",
      "default": "accept"
    }
  },
  "oidcRPMetaDataExportedVars": {
    "linid-im": {
      "email": "mail",
      "name": "cn",
      "sub": "uid",
      "preferred_username": "uid",
      "roles": "roles"
    }
  },
  "oidcRPMetaDataOptions": {
    "linid-im": {
      "oidcRPMetaDataOptionsAccessTokenClaims": 1,
      "oidcRPMetaDataOptionsAccessTokenJWT": 1,
      "oidcRPMetaDataOptionsAccessTokenSignAlg": "RS256",
      "oidcRPMetaDataOptionsIDTokenSignAlg": "RS256",
      "oidcRPMetaDataOptionsPublic": 1,
      "oidcRPMetaDataOptionsRequirePKCE": 1,
      "oidcRPMetaDataOptionsBypassConsent": 1,
      "oidcRPMetaDataOptionsClientID": "linid-im-client",
      "oidcRPMetaDataOptionsClientSecret": "linid-im-secret",
      "oidcRPMetaDataOptionsRedirectUris": "${LEMONLDAP_REDIRECT_URL}",
      "oidcRPMetaDataOptionsNoJwtHeader": 1,
      "oidcRPMetaDataOptionsIDTokenForceClaims": 1,
      "oidcRPMetaDataOptionsExtraClaims": {
        "roles": "roles"
      }
    }
  },
  "oidcServicePrivateKeySig": "${OIDC_PRIVATE_KEY}",
  "oidcServicePublicKeySig": "${OIDC_PUBLIC_KEY}",
  "passwordDB": "DBI",
  "persistentStorage": "Apache::Session::File",
  "persistentStorageOptions": {
    "Directory": "/var/lib/lemonldap-ng/psessions",
    "LockDirectory": "/var/lib/lemonldap-ng/psessions/lock"
  },
  "portal": "${LEMONLDAP_PORTAL_URL}",
  "userDB": "DBI"
}
