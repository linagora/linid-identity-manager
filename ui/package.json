{
  "name": "@linagora/linid-identity-manager-ui",
  "version": "0.0.1",
  "description": "The host app of LinID Identity Manager",
  "productName": "LinID Identity Manager",
  "contributors": [
    {
      "name": "Vincent Moittie",
      "email": "moittie.vincent@gmail.com",
      "url": "https://github.com/Zorin95670"
    },
    {
      "name": "Jordy Cabannes",
      "email": "jcabannes@linagora.com",
      "url": "https://github.com/jcabannes"
    },
    {
      "name": "Christophe Chevalier",
      "email": "cchevalier@linagora.com",
      "url": "https://github.com/christophechevalier"
    }
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "type-check": "vue-tsc --noEmit",
    "validate": "pnpm type-check && pnpm lint && pnpm format:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=dot",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@linagora/linid-im-front-corelib": "0.0.52",
    "@module-federation/enhanced": "2.1.0",
    "@quasar/extras": "1.17.0",
    "axios": "1.13.6",
    "nunjucks": "3.2.4",
    "pinia": "3.0.4",
    "quasar": "2.18.6",
    "rxjs": "7.8.2",
    "vue": "3.5.30",
    "vue-i18n": "11.3.0",
    "vue-router": "5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@intlify/unplugin-vue-i18n": "11.0.7",
    "@module-federation/vite": "1.12.3",
    "@quasar/app-vite": "2.4.1",
    "@quasar/quasar-app-extension-testing-unit-vitest": "1.2.4",
    "@quasar/vite-plugin": "1.10.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/vue": "8.1.0",
    "@types/node": "25.4.0",
    "@types/nunjucks": "3.2.6",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.6",
    "autoprefixer": "10.4.27",
    "eslint": "9.39.4",
    "eslint-plugin-headers": "1.3.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "62.8.0",
    "eslint-plugin-vue": "10.8.0",
    "globals": "17.4.0",
    "happy-dom": "20.8.3",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-checker": "0.12.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18",
    "vue-tsc": "3.2.5"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "pnpm": ">=10.32.1"
  },
  "packageManager": "pnpm@10.32.1"
}
